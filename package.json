{
  "name": "gasguard-monorepo",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "build": "tsc -b 2>&1 || true",
    "build:engine": "tsc -p libs/engine/tsconfig.json",
    "build:api": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/api/main",
    "lint": "eslint \"{apps,libs,packages}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.15.2",
    "axios-retry": "^4.5.0",
    "ethers": "^6.16.0",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "glob": "^13.0.6",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "libs/**/*.ts",
      "apps/**/*.ts",
      "!**/*.spec.ts",
      "!**/*.test.ts",
      "!**/node_modules/**"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@engine/(.*)$": "<rootDir>/libs/engine/$1",
      "^@rules/(.*)$": "<rootDir>/packages/rules/$1",
      "^@api/(.*)$": "<rootDir>/apps/api/src/$1",
      "^@cache/(.*)$": "<rootDir>/libs/cache/$1",
      "^@rpc/(.*)$": "<rootDir>/libs/rpc/$1",
      "^@monitoring/(.*)$": "<rootDir>/libs/monitoring/$1",
      "^@simulation/(.*)$": "<rootDir>/libs/simulation/$1",
      "^@chains/(.*)$": "<rootDir>/libs/chains/$1"
    }
  }
}
